# ── Evolution API (provider primário) ──────────────────────────
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=your-evolution-api-key

# Slug da instância padrão (modo single-tenant / fallback)
DEFAULT_INSTANCE_SLUG=default

# ── Provider (evolution | zapi) ────────────────────────────────
WHATSAPP_PROVIDER=evolution

# ── Z-API (provider legado / fallback) ─────────────────────────
ZAPI_BASE_URL=https://api.z-api.io
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=

# ── Redis (conversation state + rate limiting) ───────────────────
REDIS_URL=redis://localhost:6379

# ── Supabase ─────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Banco de dados (Supabase PostgreSQL) ─────────────────────────
# Obtido em: Supabase → Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres.xxxx:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_DIRECT_URL=postgresql://postgres.xxxx:password@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# ── Segurança ─────────────────────────────────────────────────────
# Chave JWT do Supabase (mesma que SUPABASE_ANON_KEY JWT secret)
JWT_SECRET=your-supabase-jwt-secret

# ── URL base da API ───────────────────────────────────────────────
API_BASE_URL=http://localhost:3001

# ── App ──────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Frontend URL (para CORS) ─────────────────────────────────────
FRONTEND_URL=http://localhost:5173
