# ── Evolution API (provider primário) ──────────────────────────
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=your-evolution-api-key

# Slug da instância padrão (modo single-tenant)
DEFAULT_INSTANCE_SLUG=default

# ── Provider (evolution | zapi) ────────────────────────────────
WHATSAPP_PROVIDER=evolution

# ── Z-API (provider legado / fallback) ─────────────────────────
ZAPI_BASE_URL=https://api.z-api.io
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=

# ── Redis (conversation state) ──────────────────────────────────
REDIS_URL=redis://localhost:6379
# Ou separado:
# REDIS_HOST=localhost
# REDIS_PORT=6379

# ── Banco de dados ───────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/zap_conecta

# ── Segurança ────────────────────────────────────────────────────
# Chave de API para autenticar requisições (header: x-api-key)
API_KEY=your-secret-api-key

# URL base da API (usada para configurar webhooks na Evolution API)
API_BASE_URL=http://localhost:3000

# ── App ──────────────────────────────────────────────────────────
PORT=3000
